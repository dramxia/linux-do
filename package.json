{
  "name": "linux-do-toolkit",
  "version": "1.1.0",
  "private": true,
  "description": "Linux.do 浏览器工具箱：Markdown 导出与阅读辅助",
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "npm run build && tsc --noEmit && node --check content.js && node --check popup.js && node --check background.js && node -e \"JSON.parse(require('fs').readFileSync('manifest.json','utf8'))\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ test/",
    "format": "prettier --write src/ test/",
    "format:check": "prettier --check src/ test/"
  },
  "keywords": [
    "chrome-extension",
    "linux-do",
    "markdown",
    "discourse"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "chrome-types": "^0.1.336",
    "esbuild": "^0.24.0",
    "eslint": "^8.57.1",
    "jsdom": "^25.0.1",
    "prettier": "^3.9.6",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
