{
  "manifest_version": 3,
  "name": "Linux.do 工具箱",
  "version": "1.1.0",
  "description": "一键复制或下载 linux.do 帖子内容为 Markdown，并提供 Base64 解码等阅读辅助能力",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "clipboardWrite", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://linux.do/*", "https://www.linux.do/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
